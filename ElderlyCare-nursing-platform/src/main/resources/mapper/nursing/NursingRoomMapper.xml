<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tong.nursing.mapper.NursingRoomMapper">

    <resultMap type="NursingRoom" id="NursingRoomResult">
        <result property="id"    column="id"    />
        <result property="roomNo"    column="room_no"    />
        <result property="floorId"    column="floor_id"    />
        <result property="roomTypeId"    column="room_type_id"    />
        <result property="status"    column="status"    />
        <result property="floorName"    column="floor_name"    />
        <result property="roomTypeName"    column="room_type_name"    />
        <result property="createBy"    column="create_by"    />
        <result property="updateBy"    column="update_by"    />
        <result property="remark"    column="remark"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectNursingRoomVo">
        select r.id, r.room_no, r.floor_id, r.room_type_id, r.status, r.create_by, r.update_by, r.remark, r.create_time, r.update_time,
               f.name as floor_name,
               t.name as room_type_name
        from nursing_room r
        left join nursing_floor f on r.floor_id = f.id
        left join nursing_room_type t on r.room_type_id = t.id
    </sql>

    <select id="selectNursingRoomList" parameterType="NursingRoom" resultMap="NursingRoomResult">
        <include refid="selectNursingRoomVo"/>
        <where>
            <if test="roomNo != null  and roomNo != ''"> and r.room_no like concat('%', #{roomNo}, '%')</if>
            <if test="floorId != null "> and r.floor_id = #{floorId}</if>
            <if test="roomTypeId != null "> and r.room_type_id = #{roomTypeId}</if>
            <if test="status != null "> and r.status = #{status}</if>
        </where>
        order by r.room_no asc
    </select>

    <select id="selectNursingRoomById" parameterType="Long" resultMap="NursingRoomResult">
        <include refid="selectNursingRoomVo"/>
        where r.id = #{id}
    </select>

    <insert id="insertNursingRoom" parameterType="NursingRoom" useGeneratedKeys="true" keyProperty="id">
        insert into nursing_room
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="roomNo != null">room_no,</if>
            <if test="floorId != null">floor_id,</if>
            <if test="roomTypeId != null">room_type_id,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="remark != null">remark,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="roomNo != null">#{roomNo},</if>
            <if test="floorId != null">#{floorId},</if>
            <if test="roomTypeId != null">#{roomTypeId},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateNursingRoom" parameterType="NursingRoom">
        update nursing_room
        <trim prefix="SET" suffixOverrides=",">
            <if test="roomNo != null">room_no = #{roomNo},</if>
            <if test="floorId != null">floor_id = #{floorId},</if>
            <if test="roomTypeId != null">room_type_id = #{roomTypeId},</if>
            <if test="status != null">status = #{status},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteNursingRoomById" parameterType="Long">
        delete from nursing_room where id = #{id}
    </delete>

    <delete id="deleteNursingRoomByIds" parameterType="String">
        delete from nursing_room where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
