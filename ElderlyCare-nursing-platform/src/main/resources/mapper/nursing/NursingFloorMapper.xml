<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tong.nursing.mapper.NursingFloorMapper">

    <resultMap type="NursingFloor" id="NursingFloorResult">
        <result property="id"    column="id"    />
        <result property="name"    column="name"    />
        <result property="floorNo"    column="floor_no"    />
        <result property="status"    column="status"    />
        <result property="createBy"    column="create_by"    />
        <result property="updateBy"    column="update_by"    />
        <result property="remark"    column="remark"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectNursingFloorVo">
        select id, name, floor_no, status, create_by, update_by, remark, create_time, update_time from nursing_floor
    </sql>

    <select id="selectNursingFloorList" parameterType="NursingFloor" resultMap="NursingFloorResult">
        <include refid="selectNursingFloorVo"/>
        <where>
            <if test="name != null  and name != ''"> and name like concat('%', #{name}, '%')</if>
            <if test="status != null "> and status = #{status}</if>
        </where>
        order by floor_no asc
    </select>

    <select id="selectNursingFloorAll" resultMap="NursingFloorResult">
        <include refid="selectNursingFloorVo"/>
        where status = 1
        order by floor_no asc
    </select>

    <select id="selectNursingFloorById" parameterType="Long" resultMap="NursingFloorResult">
        <include refid="selectNursingFloorVo"/>
        where id = #{id}
    </select>

    <!-- 查询单个楼层的树形结构（含房间和床位） -->
    <resultMap type="com.tong.nursing.vo.FloorTreeVO" id="FloorTreeResult">
        <id property="id" column="floor_id"/>
        <result property="name" column="floor_name"/>
        <result property="floorNo" column="floor_no"/>
        <result property="status" column="floor_status"/>
        <collection property="roomList" ofType="com.tong.nursing.vo.FloorTreeVO$RoomVO">
            <id property="id" column="room_id"/>
            <result property="roomNo" column="room_no"/>
            <result property="roomTypeId" column="room_type_id"/>
            <result property="roomTypeName" column="room_type_name"/>
            <result property="status" column="room_status"/>
            <collection property="bedList" ofType="com.tong.nursing.vo.FloorTreeVO$BedVO">
                <id property="id" column="bed_id"/>
                <result property="bedNo" column="bed_no"/>
                <result property="bedStatus" column="bed_status"/>
                <result property="deviceBind" column="device_bind"/>
                <result property="deviceNo" column="device_no"/>
                <result property="status" column="bed_status_flag"/>
            </collection>
        </collection>
    </resultMap>

    <select id="selectFloorTreeById" parameterType="Long" resultMap="FloorTreeResult">
        select
            f.id as floor_id,
            f.name as floor_name,
            f.floor_no,
            f.status as floor_status,
            r.id as room_id,
            r.room_no,
            r.room_type_id,
            rt.name as room_type_name,
            r.status as room_status,
            b.id as bed_id,
            b.bed_no,
            b.bed_status,
            b.device_bind,
            b.device_no,
            b.status as bed_status_flag
        from nursing_floor f
        left join nursing_room r on f.id = r.floor_id
        left join nursing_room_type rt on r.room_type_id = rt.id
        left join nursing_bed b on r.id = b.room_id
        where f.id = #{id}
        order by f.floor_no asc, r.room_no asc, b.bed_no asc
    </select>

    <insert id="insertNursingFloor" parameterType="NursingFloor" useGeneratedKeys="true" keyProperty="id">
        insert into nursing_floor
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="name != null">name,</if>
            <if test="floorNo != null">floor_no,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="remark != null">remark,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="name != null">#{name},</if>
            <if test="floorNo != null">#{floorNo},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateNursingFloor" parameterType="NursingFloor">
        update nursing_floor
        <trim prefix="SET" suffixOverrides=",">
            <if test="name != null">name = #{name},</if>
            <if test="floorNo != null">floor_no = #{floorNo},</if>
            <if test="status != null">status = #{status},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteNursingFloorById" parameterType="Long">
        delete from nursing_floor where id = #{id}
    </delete>

    <delete id="deleteNursingFloorByIds" parameterType="String">
        delete from nursing_floor where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
