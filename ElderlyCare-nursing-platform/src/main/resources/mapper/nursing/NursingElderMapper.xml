<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tong.nursing.mapper.NursingElderMapper">

    <resultMap type="NursingElder" id="NursingElderResult">
        <result property="id"    column="id"    />
        <result property="name"    column="name"    />
        <result property="gender"    column="gender"    />
        <result property="birthday"    column="birthday"    />
        <result property="age"    column="age"    />
        <result property="idCard"    column="id_card"    />
        <result property="phone"    column="phone"    />
        <result property="address"    column="address"    />
        <result property="avatar"    column="avatar"    />
        <result property="levelId"    column="level_id"    />
        <result property="bedId"    column="bed_id"    />
        <result property="checkInStatus"    column="check_in_status"    />
        <result property="healthStatus"    column="health_status"    />
        <result property="status"    column="status"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
        <result property="levelName"    column="level_name"    />
        <result property="bedName"    column="bed_name"    />
    </resultMap>

    <sql id="selectNursingElderVo">
        select e.id, e.name, e.gender, e.birthday, e.age, e.id_card, e.phone, e.address, e.avatar,
               e.level_id, e.bed_id, e.check_in_status, e.health_status, e.status,
               e.create_by, e.create_time, e.update_by, e.update_time, e.remark,
               l.name as level_name, b.bed_no as bed_name
        from nursing_elder e
        left join nursing_level l on e.level_id = l.id
        left join nursing_bed b on e.bed_id = b.id
    </sql>

    <select id="selectNursingElderList" parameterType="NursingElder" resultMap="NursingElderResult">
        <include refid="selectNursingElderVo"/>
        <where>
            <if test="name != null and name != ''"> and e.name like concat('%', #{name}, '%')</if>
            <if test="gender != null"> and e.gender = #{gender}</if>
            <if test="idCard != null and idCard != ''"> and e.id_card = #{idCard}</if>
            <if test="phone != null and phone != ''"> and e.phone = #{phone}</if>
            <if test="checkInStatus != null"> and e.check_in_status = #{checkInStatus}</if>
            <if test="healthStatus != null"> and e.health_status = #{healthStatus}</if>
            <if test="status != null"> and e.status = #{status}</if>
            <if test="levelId != null"> and e.level_id = #{levelId}</if>
            <if test="bedId != null"> and e.bed_id = #{bedId}</if>
        </where>
        order by e.id desc
    </select>

    <select id="selectNursingElderById" parameterType="Long" resultMap="NursingElderResult">
        <include refid="selectNursingElderVo"/>
        where e.id = #{id}
    </select>

    <insert id="insertNursingElder" parameterType="NursingElder" useGeneratedKeys="true" keyProperty="id">
        insert into nursing_elder
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="name != null">name,</if>
            <if test="gender != null">gender,</if>
            <if test="birthday != null">birthday,</if>
            <if test="age != null">age,</if>
            <if test="idCard != null">id_card,</if>
            <if test="phone != null">phone,</if>
            <if test="address != null">address,</if>
            <if test="avatar != null">avatar,</if>
            <if test="levelId != null">level_id,</if>
            <if test="bedId != null">bed_id,</if>
            <if test="checkInStatus != null">check_in_status,</if>
            <if test="healthStatus != null">health_status,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="name != null">#{name},</if>
            <if test="gender != null">#{gender},</if>
            <if test="birthday != null">#{birthday},</if>
            <if test="age != null">#{age},</if>
            <if test="idCard != null">#{idCard},</if>
            <if test="phone != null">#{phone},</if>
            <if test="address != null">#{address},</if>
            <if test="avatar != null">#{avatar},</if>
            <if test="levelId != null">#{levelId},</if>
            <if test="bedId != null">#{bedId},</if>
            <if test="checkInStatus != null">#{checkInStatus},</if>
            <if test="healthStatus != null">#{healthStatus},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateNursingElder" parameterType="NursingElder">
        update nursing_elder
        <trim prefix="SET" suffixOverrides=",">
            <if test="name != null">name = #{name},</if>
            <if test="gender != null">gender = #{gender},</if>
            <if test="birthday != null">birthday = #{birthday},</if>
            <if test="age != null">age = #{age},</if>
            <if test="idCard != null">id_card = #{idCard},</if>
            <if test="phone != null">phone = #{phone},</if>
            <if test="address != null">address = #{address},</if>
            <if test="avatar != null">avatar = #{avatar},</if>
            <if test="levelId != null">level_id = #{levelId},</if>
            <if test="bedId != null">bed_id = #{bedId},</if>
            <if test="checkInStatus != null">check_in_status = #{checkInStatus},</if>
            <if test="healthStatus != null">health_status = #{healthStatus},</if>
            <if test="status != null">status = #{status},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteNursingElderById" parameterType="Long">
        delete from nursing_elder where id = #{id}
    </delete>

    <delete id="deleteNursingElderByIds" parameterType="String">
        delete from nursing_elder where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
