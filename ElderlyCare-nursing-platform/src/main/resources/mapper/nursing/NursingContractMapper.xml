<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tong.nursing.mapper.NursingContractMapper">

    <resultMap type="NursingContract" id="NursingContractResult">
        <result property="id"    column="id"    />
        <result property="contractNo"    column="contract_no"    />
        <result property="elderId"    column="elder_id"    />
        <result property="elderName"    column="elder_name"    />
        <result property="checkInId"    column="check_in_id"    />
        <result property="contractType"    column="contract_type"    />
        <result property="signDate"    column="sign_date"    />
        <result property="startDate"    column="start_date"    />
        <result property="endDate"    column="end_date"    />
        <result property="totalAmount"    column="total_amount"    />
        <result property="status"    column="status"    />
        <result property="terminateReason"    column="terminate_reason"    />
        <result property="terminateDate"    column="terminate_date"    />
        <result property="createBy"    column="create_by"    />
        <result property="updateBy"    column="update_by"    />
        <result property="remark"    column="remark"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectNursingContractVo">
        select c.id, c.contract_no, c.elder_id, c.check_in_id, c.contract_type,
               c.sign_date, c.start_date, c.end_date, c.total_amount, c.status,
               c.terminate_reason, c.terminate_date, c.create_by, c.update_by,
               c.remark, c.create_time, c.update_time,
               e.name as elder_name
        from nursing_contract c
        left join nursing_elder e on c.elder_id = e.id
    </sql>

    <select id="selectNursingContractList" parameterType="NursingContract" resultMap="NursingContractResult">
        <include refid="selectNursingContractVo"/>
        <where>
            <if test="contractNo != null  and contractNo != ''"> and c.contract_no like concat('%', #{contractNo}, '%')</if>
            <if test="elderId != null "> and c.elder_id = #{elderId}</if>
            <if test="contractType != null "> and c.contract_type = #{contractType}</if>
            <if test="status != null "> and c.status = #{status}</if>
            <if test="elderName != null  and elderName != ''"> and e.name like concat('%', #{elderName}, '%')</if>
        </where>
        order by c.id desc
    </select>

    <select id="selectNursingContractById" parameterType="Long" resultMap="NursingContractResult">
        <include refid="selectNursingContractVo"/>
        where c.id = #{id}
    </select>

    <insert id="insertNursingContract" parameterType="NursingContract" useGeneratedKeys="true" keyProperty="id">
        insert into nursing_contract
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="contractNo != null">contract_no,</if>
            <if test="elderId != null">elder_id,</if>
            <if test="checkInId != null">check_in_id,</if>
            <if test="contractType != null">contract_type,</if>
            <if test="signDate != null">sign_date,</if>
            <if test="startDate != null">start_date,</if>
            <if test="endDate != null">end_date,</if>
            <if test="totalAmount != null">total_amount,</if>
            <if test="status != null">status,</if>
            <if test="terminateReason != null">terminate_reason,</if>
            <if test="terminateDate != null">terminate_date,</if>
            <if test="createBy != null">create_by,</if>
            <if test="remark != null">remark,</if>
            <if test="createTime != null">create_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="contractNo != null">#{contractNo},</if>
            <if test="elderId != null">#{elderId},</if>
            <if test="checkInId != null">#{checkInId},</if>
            <if test="contractType != null">#{contractType},</if>
            <if test="signDate != null">#{signDate},</if>
            <if test="startDate != null">#{startDate},</if>
            <if test="endDate != null">#{endDate},</if>
            <if test="totalAmount != null">#{totalAmount},</if>
            <if test="status != null">#{status},</if>
            <if test="terminateReason != null">#{terminateReason},</if>
            <if test="terminateDate != null">#{terminateDate},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createTime != null">#{createTime},</if>
        </trim>
    </insert>

    <update id="updateNursingContract" parameterType="NursingContract">
        update nursing_contract
        <trim prefix="SET" suffixOverrides=",">
            <if test="contractNo != null">contract_no = #{contractNo},</if>
            <if test="elderId != null">elder_id = #{elderId},</if>
            <if test="checkInId != null">check_in_id = #{checkInId},</if>
            <if test="contractType != null">contract_type = #{contractType},</if>
            <if test="signDate != null">sign_date = #{signDate},</if>
            <if test="startDate != null">start_date = #{startDate},</if>
            <if test="endDate != null">end_date = #{endDate},</if>
            <if test="totalAmount != null">total_amount = #{totalAmount},</if>
            <if test="status != null">status = #{status},</if>
            <if test="terminateReason != null">terminate_reason = #{terminateReason},</if>
            <if test="terminateDate != null">terminate_date = #{terminateDate},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteNursingContractById" parameterType="Long">
        delete from nursing_contract where id = #{id}
    </delete>

    <delete id="deleteNursingContractByIds" parameterType="String">
        delete from nursing_contract where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>
